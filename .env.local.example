# Copy this file to .env.local and fill in your Deepgram API key.
#
# VITE_DEEPGRAM_API_KEY — Recommended for development.
# Uses the raw API key directly, bypassing the grantToken endpoint.
# The key must have the "Voice Agent" product enabled in your Deepgram console.
#   https://console.deepgram.com -> API Keys -> create / select a key
#
# If this is left blank the app falls back to fetching a short-lived token from
# the cookie-api backend (/api/chat-token). That approach sometimes fails for
# Voice Agent because grantToken JWT tokens use a different auth scheme than
# the API key format Voice Agent expects.

VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Optional: override the backend URL if the API runs on a non-default port
VITE_API_URL=http://localhost:3000
